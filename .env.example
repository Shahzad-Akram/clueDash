# Copy to .env.local for local development.
# For EAS production builds, set these as EAS secrets (eas secret:create).
# Do NOT add Google test AdMob unit IDs to production secrets.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Optional — overrides app.json admob interstitial IDs (dev/test only in production builds)
# EXPO_PUBLIC_ADMOB_ANDROID_INTERSTITIAL_UNIT_ID=
# EXPO_PUBLIC_ADMOB_IOS_INTERSTITIAL_UNIT_ID=

# Required for store submission — hosted privacy policy URL
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://www.remoterun.uk/app-privacy-policy

# Play Console Data safety — account deletion web link
# EXPO_PUBLIC_ACCOUNT_DELETION_URL=https://www.remoterun.uk/app-data-deletion
