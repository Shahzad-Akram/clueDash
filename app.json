{
  "expo": {
    "name": "GuessUp",
    "slug": "GuessUp",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "guessup",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "buildNumber": "3",
      "bundleIdentifier": "com.digitalukapps.GuessUp",
      "infoPlist": {
        "CFBundleDisplayName": "GuessUp",
        "NSUserTrackingUsageDescription": "This identifier will be used to deliver personalized ads to you.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.digitalukapps.GuessUp",
      "versionCode": 4,
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "blockedPermissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.RECORD_AUDIO"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "com.google.android.gms.permission.AD_ID",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-audio",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-5967256865674252~2285647900",
          "iosAppId": "ca-app-pub-5967256865674252~6315196711"
        }
      ],
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "This identifier will be used to deliver personalized ads to you."
        }
      ]
    ],
    "extra": {
      "admob": {
        "android": {
          "appId": "ca-app-pub-5967256865674252~2285647900",
          "interstitialUnitId": "ca-app-pub-5967256865674252/8916459265"
        },
        "ios": {
          "appId": "ca-app-pub-5967256865674252~6315196711",
          "interstitialUnitId": "ca-app-pub-5967256865674252/5002115045"
        }
      },
      "legal": {
        "privacyPolicyUrl": "https://www.remoterun.uk/app-privacy-policy",
        "accountDeletionUrl": "https://www.remoterun.uk/app-data-deletion"
      },
      "router": {},
      "eas": {
        "projectId": "4f5e00ef-fa4b-4a4c-a133-9e921d58b4b4"
      }
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "thebabybless"
  }
}
